diff --git a/frontend/src/styles/main.css b/frontend/src/styles/main.css
index bc2f11e6..0e30fb33 100644
--- a/frontend/src/styles/main.css
+++ b/frontend/src/styles/main.css
@@ -1694,6 +1694,212 @@ html[data-theme="dark"] .nm-toast {
     color: var(--text-heading);
 }
 
+/* ============================================================================
+   IMP-015: Notification Panel — Glassmorphic Dropdown
+   Attaches to #notification-bell (injected by header-normalize.ts).
+   RTL-safe, dark-mode safe, accessible, 200ms enter/exit animation.
+   ============================================================================ */
+.nm-notif-panel {
+    position: fixed;
+    z-index: var(--z-toast, 9999);
+    width: min(380px, calc(100vw - 24px));
+    max-height: min(520px, calc(100vh - 120px));
+    border-radius: var(--radius-lg, 12px);
+    background: var(--surface-elevated, rgba(255,255,255,0.95));
+    backdrop-filter: blur(20px);
+    -webkit-backdrop-filter: blur(20px);
+    box-shadow: 0 12px 40px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.06);
+    border: 1px solid var(--border-light, rgba(0,0,0,0.08));
+    display: flex;
+    flex-direction: column;
+    overflow: hidden;
+    /* Entry animation */
+    opacity: 0;
+    transform: translateY(-8px) scale(0.97);
+    transition: opacity 0.2s ease, transform 0.2s cubic-bezier(0.4,0,0.2,1);
+    pointer-events: none;
+}
+.nm-notif-panel-open {
+    opacity: 1;
+    transform: translateY(0) scale(1);
+    pointer-events: auto;
+}
+
+.nm-notif-header {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    padding: 14px 16px 10px;
+    border-bottom: 1px solid var(--border-subtle, rgba(0,0,0,0.06));
+}
+.nm-notif-title {
+    font-size: 0.9375rem;
+    font-weight: 700;
+    color: var(--text-heading, #0f172a);
+    margin: 0;
+}
+.nm-notif-mark-all {
+    background: none;
+    border: none;
+    cursor: pointer;
+    font-size: 0.75rem;
+    font-weight: 600;
+    color: var(--trust-blue, #1a73e8);
+    padding: 4px 8px;
+    border-radius: 6px;
+    transition: background 0.15s ease;
+    white-space: nowrap;
+}
+.nm-notif-mark-all:hover {
+    background: color-mix(in srgb, var(--trust-blue, #1a73e8) 8%, transparent);
+}
+
+.nm-notif-body {
+    flex: 1;
+    overflow-y: auto;
+    overscroll-behavior: contain;
+    -webkit-overflow-scrolling: touch;
+    scrollbar-width: thin;
+}
+.nm-notif-body::-webkit-scrollbar { width: 4px; }
+.nm-notif-body::-webkit-scrollbar-track { background: transparent; }
+.nm-notif-body::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 4px; }
+
+.nm-notif-loading,
+.nm-notif-empty {
+    display: flex;
+    flex-direction: column;
+    align-items: center;
+    justify-content: center;
+    gap: 8px;
+    padding: 40px 16px;
+    color: var(--text-muted, #94a3b8);
+    font-size: 0.8125rem;
+}
+
+/* ── Notification Item ──────────────────────────────────────────────── */
+.nm-notif-item {
+    display: flex;
+    align-items: flex-start;
+    gap: 12px;
+    padding: 12px 16px;
+    border-bottom: 1px solid var(--border-subtle, rgba(0,0,0,0.04));
+    cursor: default;
+    transition: background 0.12s ease;
+}
+.nm-notif-item:last-child { border-bottom: none; }
+.nm-notif-item:hover {
+    background: rgba(0,0,0,0.02);
+}
+
+/* Unread indicator: left border accent */
+.nm-notif-unread {
+    border-inline-start: 3px solid var(--trust-blue, #1a73e8);
+    background: color-mix(in srgb, var(--trust-blue, #1a73e8) 3%, transparent);
+}
+.nm-notif-read {
+    border-inline-start: 3px solid transparent;
+    opacity: 0.7;
+}
+
+.nm-notif-item-icon {
+    flex-shrink: 0;
+    width: 32px;
+    height: 32px;
+    border-radius: 8px;
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    background: var(--bg-subtle, rgba(0,0,0,0.04));
+    font-size: 16px;
+    margin-top: 2px;
+}
+
+.nm-notif-item-content {
+    flex: 1;
+    min-width: 0;
+}
+.nm-notif-item-title {
+    font-size: 0.8125rem;
+    font-weight: 600;
+    color: var(--text-heading, #0f172a);
+    margin: 0 0 2px;
+    line-height: 1.3;
+}
+.nm-notif-item-body {
+    font-size: 0.75rem;
+    color: var(--text-muted, #64748b);
+    margin: 0 0 4px;
+    line-height: 1.4;
+    display: -webkit-box;
+    -webkit-line-clamp: 2;
+    -webkit-box-orient: vertical;
+    overflow: hidden;
+}
+.nm-notif-item-time {
+    font-size: 0.6875rem;
+    color: var(--text-muted, #94a3b8);
+}
+
+.nm-notif-item-mark {
+    flex-shrink: 0;
+    background: none;
+    border: none;
+    cursor: pointer;
+    width: 28px;
+    height: 28px;
+    border-radius: 6px;
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    color: var(--text-muted, #94a3b8);
+    transition: background 0.12s ease, color 0.12s ease;
+    margin-top: 2px;
+}
+.nm-notif-item-mark:hover {
+    background: color-mix(in srgb, var(--smoky-jade, #109173) 10%, transparent);
+    color: var(--smoky-jade, #109173);
+}
+
+/* ── Badge pulse animation ──────────────────────────────────────────── */
+@keyframes notifPulse {
+    0% { transform: scale(1); }
+    50% { transform: scale(1.25); }
+    100% { transform: scale(1); }
+}
+.nm-notif-pulse { animation: notifPulse 0.4s ease; }
+
+/* ── Dark Mode ──────────────────────────────────────────────────────── */
+html[data-theme="dark"] .nm-notif-panel {
+    background: rgba(20, 20, 25, 0.95);
+    border-color: rgba(255,255,255,0.08);
+    box-shadow: 0 12px 40px rgba(0,0,0,0.4), 0 2px 8px rgba(0,0,0,0.2);
+}
+html[data-theme="dark"] .nm-notif-header {
+    border-color: rgba(255,255,255,0.06);
+}
+html[data-theme="dark"] .nm-notif-item:hover {
+    background: rgba(255,255,255,0.03);
+}
+html[data-theme="dark"] .nm-notif-unread {
+    background: rgba(26, 115, 232, 0.06);
+}
+html[data-theme="dark"] .nm-notif-item-icon {
+    background: rgba(255,255,255,0.06);
+}
+html[data-theme="dark"] .nm-notif-body::-webkit-scrollbar-thumb {
+    background: rgba(255,255,255,0.1);
+}
+
+/* ── Mobile: full-width panel ───────────────────────────────────────── */
+@media (max-width: 480px) {
+    .nm-notif-panel {
+        width: calc(100vw - 16px);
+        inset-inline-start: 8px !important;
+        inset-inline-end: 8px !important;
+    }
+}
+
 /* ============================================================================
    P2-DS-002 FIX: Button Loading State
    ============================================================================ */
