# Nammerha Backend — Environment Variables
# Copy to .env and fill in values

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nammerha
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Auth0 (Primary Auth — RS256 JWKS) ────────────────────
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://api.nammerha.com

# Security (legacy HS256 — fallback for dev/internal tokens)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_EXPIRY=24h

# Spatial Proof
GPS_PROXIMITY_THRESHOLD_METERS=100

# Storage Service (MinIO — self-hosted S3-compatible on your server)
STORAGE_PROVIDER=minio
STORAGE_BUCKET=nammerha-uploads
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://nammerha-minio:9000
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_URL=
STORAGE_MAX_SIZE_MB=50
STORAGE_PRESIGN_EXPIRY=3600

# MinIO Credentials (shared between MinIO container + backend)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ── Payment Gateways ────────────────────────────────────
PLATFORM_BASE_URL=https://nammerha.com
PAYMENT_WEBHOOK_SECRET=CHANGE_ME_IN_PRODUCTION

# CORS (production only — no localhost)
CORS_ORIGINS=https://nammerha.com,https://www.nammerha.com

# Visa (Click to Pay)
VISA_API_KEY=
VISA_MERCHANT_ID=
VISA_API_BASE_URL=https://sandbox.api.visa.com

# Fatora
FATORA_API_KEY=
FATORA_MERCHANT_CODE=
FATORA_API_BASE_URL=https://api.fatora.io

# File Storage
STORAGE_BUCKET_URL=https://storage.nammerha.com

# ── Self-Hosted SMTP (Postfix Container) ───────────────
# docker compose -f docker-compose.smtp.yml up -d
SMTP_HOST=nammerha-smtp
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=noreply@nammerha.com
