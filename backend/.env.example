# Nammerha Backend — Environment Variables
# Copy to .env and fill in values

# Server
PORT=3001
NODE_ENV=development
# V-006: Required alongside NODE_ENV=development to enable X-User-Id header bypass.
# Set to 'true' ONLY for local development. NEVER enable in production.
# DEV_AUTH_BYPASS=true

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nammerha
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Auth0 (Primary Auth — RS256 JWKS) ────────────────────
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://api.nammerha.com

# Security (legacy HS256 — fallback for dev/internal tokens)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_EXPIRY=24h

# Spatial Proof
GPS_PROXIMITY_THRESHOLD_METERS=100

# Storage Service (MinIO — self-hosted S3-compatible on your server)
STORAGE_PROVIDER=minio
STORAGE_BUCKET=nammerha-uploads
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://nammerha-minio:9000
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_URL=
STORAGE_MAX_SIZE_MB=50
STORAGE_PRESIGN_EXPIRY=3600

# MinIO Credentials (shared between MinIO container + backend)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ── Payment Gateways ────────────────────────────────────
PLATFORM_BASE_URL=https://nammerha.com
PAYMENT_WEBHOOK_SECRET=CHANGE_ME_IN_PRODUCTION
# Maximum single payment amount in cents ($100,000 default)
MAX_PAYMENT_CENTS=10000000

# ── Redis (Distributed Locks for Webhook Idempotency) ──
# Use redis://nammerha-redis:6379 for Docker bridge network
REDIS_URL=redis://localhost:6379

# CORS (production only — no localhost)
CORS_ORIGINS=https://nammerha.com,https://www.nammerha.com

# Visa (Click to Pay)
VISA_API_KEY=
VISA_MERCHANT_ID=
VISA_API_BASE_URL=https://sandbox.api.visa.com

# Fatora
FATORA_API_KEY=
FATORA_MERCHANT_CODE=
FATORA_API_BASE_URL=https://api.fatora.io

# File Storage
STORAGE_BUCKET_URL=https://storage.nammerha.com

# ── Email Service (Resend) ─────────────────────────────
RESEND_API_KEY=re_123456789
SMTP_FROM=noreply@nammerha.com

# ── Georavity Routing Engine (self-hosted Valhalla) ────
GEORAVITY_URL=http://localhost:8002
# Use http://georavity-engine:8002 for Docker bridge network

# ── MapTiler (Basemap Tiles) ───────────────────────────
VITE_MAPTILER_API_KEY=

# ── Firebase Cloud Messaging (Push Notifications) ─────
# Required: Firebase project ID (from Firebase Console)
FCM_PROJECT_ID=nammerha-platform

# Auth Mode 1 (recommended for Docker/K8s): Inline service account JSON
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# Auth Mode 2 (recommended for dev/GCE): Path to service account JSON file
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/fcm-service-account.json

# Auth Mode 3: Application Default Credentials (automatic on GCE/Cloud Run)
# No env var needed — google-auth-library auto-discovers credentials
