# Nammerha Backend — Environment Variables
# Copy to .env and fill in values

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nammerha
DB_POOL_MIN=2
DB_POOL_MAX=10

# Security
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_EXPIRY=24h

# Spatial Proof
GPS_PROXIMITY_THRESHOLD_METERS=100

# Payment Gateway (placeholder)
PAYMENT_GATEWAY_URL=https://api.fatora.io/v1
PAYMENT_GATEWAY_API_KEY=sk_test_placeholder

# File Storage (placeholder)
STORAGE_BUCKET_URL=https://storage.nammerha.com
